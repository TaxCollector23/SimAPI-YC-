rules_version = '2';

// SimAPI Firestore rules.
//
// Every user can read/write their OWN profile and can create events tagged
// with their own uid — nobody can read another user's data from the client.
// An admin console reads across all users via the Firebase Admin SDK on a
// trusted server (a service account, not exposed to any browser), which
// bypasses these rules entirely — that's the correct, secure pattern for
// admin access, not a client-side "isAdmin" read rule.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      // Users can update their own profile, but never their own `banned`
      // field — only the Admin SDK (server-side, bypasses these rules) can.
      allow update: if request.auth != null && request.auth.uid == uid
                    && !("banned" in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if false;
    }

    match /events/{eventId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read, update, delete: if false; // events are write-once from the client, read only via Admin SDK
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
